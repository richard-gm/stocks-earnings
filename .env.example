# ── Required: Supabase (L2 cache + persistence) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ── Required: Anthropic (Twitter analysis via Claude) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional — this is the default

# ── Twitter scraping (optional — omit to run in mock mode) ───────────────────
# Path INSIDE the container. Mount the file with -v when running Docker.
# TWITTER_COOKIES_FILE=/app/config/twitter-cookies.json

# ── Market data APIs (optional — features degrade gracefully without them) ────
# FMP_API_KEY=your-fmp-key               # Financial Modeling Prep
# ALPHA_VANTAGE_API_KEY=your-av-key
# MARKETDATA_API_KEY=your-md-key

# ── Tastytrade (enables LIVE mode for earnings — omit for MOCK mode) ──────────
# TASTYTRADE_USERNAME=your@email.com
# TASTYTRADE_PASSWORD=your-password
# TASTYTRADE_BASE_URL=https://api.tastytrade.com

# ── Kronos ML signals (optional) ─────────────────────────────────────────────
# KRONOS_API_URL=https://your-kronos-url
# KRONOS_API_KEY=your-kronos-key

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_FILE=/logs/logs.txt   # default — override to change log path
