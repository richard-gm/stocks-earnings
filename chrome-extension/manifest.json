{
  "manifest_version": 3,
  "name": "X Tweet Collector",
  "version": "1.1",
  "description": "Collect tweets from X profiles as you browse — exports CSV/JSON for analysis",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X Tweet Collector"
  },
  "background": {
    "service_worker": "background.js"
  }
}
